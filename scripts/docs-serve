#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

export NO_MKDOCS_2_WARNING=1
unset VIRTUAL_ENV

cd "$repo_root/docs"
exec uv run watchmedo auto-restart \
  --directory "$repo_root/docs" \
  --directory "$repo_root/bluebird-dt" \
  --directory "$repo_root/bluebird-api" \
  --directory "$repo_root/bluebird-gymnasium" \
  --directory "$repo_root/bluebird-hmi" \
  --patterns "*.md;*.py;*.yml" \
  --ignore-patterns "*/.venv/*;*/site/*;*/__pycache__/*" \
  --ignore-directories \
  --recursive \
  --debounce-interval 0.5 \
  --signal SIGTERM \
  --no-restart-on-command-exit \
  -- "$script_dir/docs-serve-inner" "$@"
